# Database
DATABASE_URL=postgresql://user:password@localhost:5432/forex_agent

# Market Data Provider — 'finnhub' (Phase 1-2) | 'twelvedata' (Phase 3+)
MARKET_DATA_PROVIDER=twelvedata

# Finnhub (Phase 1-2 — Free tier available)
FINNHUB_API_KEY=your_finnhub_key
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# Twelve Data (Phase 3+ — $8/month)
TWELVEDATA_API_KEY=your_twelvedata_key
TWELVEDATA_BASE_URL=https://api.twelvedata.com

# Anthropic Claude AI
ANTHROPIC_API_KEY=your_anthropic_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI Embeddings (text-embedding-3-small)
OPENAI_API_KEY=your_openai_key

# Default user ID for single-user MVP
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# Notifications
LINE_NOTIFY_TOKEN=your_line_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Comma-separated Telegram numeric user IDs allowed to use the bot (e.g. 123456789,987654321)
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id
# Public HTTPS URL for Telegram webhook (e.g. https://xxxx.ngrok.io or your server URL)
TELEGRAM_WEBHOOK_URL=https://your-domain.com

# Server
PORT=3000
NODE_ENV=development
